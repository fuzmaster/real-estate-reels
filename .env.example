# Local Windows example
PORT=3000
ASSETS_ROOT=C:\Sites\RealEstate-Reels-Web\remotion\public
REMOTION_PROJECT=C:\Sites\RealEstate-Reels-Web\remotion
OUTPUT_ROOT=C:\Sites\RealEstate-Reels-Web\remotion\out
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
DISABLE_AUTO_OPEN=0
# Optional: enables Google Places property autocomplete in the client app.
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key
# Optional: enables sign-in and cloud slideshow backups in the client app.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
# VITE_SUPABASE_PROJECT_BUCKET=project-zips

# Hosted Render/Railway example
# PORT=3000
# DATA_ROOT=/var/data
# ASSETS_ROOT=/var/data/assets
# REMOTION_PROJECT=/app/remotion
# OUTPUT_ROOT=/var/data/outputs
# CORS_ORIGIN=https://real-estate-reels.vercel.app
# DISABLE_AUTO_OPEN=1
# CHROME_PATH=/usr/bin/chromium
# REMOTION_TIMEOUT_MS=300000
# REMOTION_CONCURRENCY=1
# REMOTION_X264_PRESET=veryfast
# REMOTION_CRF=24
# REMOTION_AUDIO_BITRATE=128k
# REMOTION_JPEG_QUALITY=72
# REMOTION_IMAGE_FORMAT=jpeg
# REMOTION_MEDIA_CACHE_BYTES=33554432
# REMOTION_OFFTHREADVIDEO_CACHE_BYTES=16777216
# REMOTION_GL=swangle
# RENDER_PHOTO_MAX_DIMENSION=2160
# RENDER_PHOTO_JPEG_QUALITY=4
