# =============================================================
#  Genera Reels Web — local environment config
#  Copy this file to .env and fill in your values.
#  DO NOT commit .env — it contains machine-specific paths.
# =============================================================

# Path to your local copy of the campaign asset folders.
# This folder should contain a Projects/ subdirectory.
# Windows: ASSETS_ROOT=C:\Users\YourName\Dropbox\Genera Assets
# Mac:     ASSETS_ROOT=/Users/yourname/Dropbox/Genera Assets
ASSETS_ROOT=

# Path to your local clone of the Genera-Reels Remotion project.
# Windows: REMOTION_PROJECT=C:\Users\YourName\Dropbox\Remotion Projects\Genera-Reels
# Mac:     REMOTION_PROJECT=/Users/yourname/Dropbox/Remotion Projects/Genera-Reels
REMOTION_PROJECT=

# Port for the web server (default: 3000)
PORT=3000
